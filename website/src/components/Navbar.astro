---
import { Image } from "astro:assets";
import logo from "../assets/Logo_Manao_weiss.webp";

const links = [
  { label: "Willkommen", href: "/" },
  { label: "Intention", href: "/intention" },
  { label: "Angebote", href: "/angebote" },
  { label: "Arbeitsweise", href: "/arbeitsweise" },
  { label: "Über Mich", href: "/about-me" },
  { label: "Kontakt", href: "/kontakt" },
  { label: "Aktuelles", href: "/news" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<nav
  class="bg-manao sticky top-0 z-50 flex items-center justify-between gap-4 px-4 py-2 text-white shadow-md md:px-6 lg:px-8"
>
  <a
    href="/"
    class="flex shrink-0 items-center"
    aria-label="manao Startseite"
  >
    <Image src={logo} alt="manao Logo" class="h-10 w-auto" loading="eager" />
  </a>

  <div class="flex items-center">
    <details class="dropdown dropdown-end xl:hidden">
      <summary
        class="btn btn-ghost list-none text-white [&::-webkit-details-marker]:hidden"
        aria-label="Menü öffnen"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </summary>
      <ul
        class="menu menu-sm dropdown-content bg-manao z-10 mt-3 w-52 p-2 shadow"
      >
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[{ "is-active": currentPath === link.href }]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>

    <ul class="menu menu-horizontal hidden flex-nowrap px-1 xl:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[{ "is-active": currentPath === link.href }]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const dropdown = document.querySelector<HTMLDetailsElement>(
    "nav details.dropdown",
  );
  if (dropdown) {
    // Bei Klick auf einen Link schließen
    dropdown.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        dropdown.open = false;
      });
    });
    // Beim Tippen/Klicken außerhalb schließen
    document.addEventListener("click", (event) => {
      if (dropdown.open && !dropdown.contains(event.target as Node)) {
        dropdown.open = false;
      }
    });
  }
</script>

<style>
  nav :global(.menu :where(li > a)) {
    background-color: transparent;
    text-transform: uppercase;
    text-decoration-line: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.35rem;
    transition: text-decoration-color 300ms ease;
    white-space: nowrap;
  }
  nav :global(.menu :where(li > a):hover),
  nav :global(.menu :where(li > a):focus),
  nav :global(.menu :where(li > a.is-active)) {
    background-color: transparent;
    text-decoration-color: currentColor;
  }
  nav :global(.menu-horizontal > li:not(:last-child)) {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.25rem;
  }
  nav :global(.menu-horizontal > li:not(:last-child) > a) {
    flex: 0 0 auto;
  }
  nav :global(.menu-horizontal > li:not(:last-child)::after) {
    content: "|";
    color: white;
    flex: 0 0 auto;
    pointer-events: none;
  }
</style>
