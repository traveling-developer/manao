---
import Layout from "../layouts/Layout.astro";
import ContactButtons from "../components/ContactButtons.astro";
---

<Layout
  title="Das Licht in mir - Kurs I"
  description="Kurs I: Vertiefung von emotionaler und sozialer Kompetenz für Vorschulkinder und Kinder der 1. Klasse."
>
  <main>
    <section class="mx-auto max-w-3xl px-5 py-12 md:py-16">
      <div class="space-y-10">
        <header class="space-y-5">
          <h1
            class="font-licorice text-manao text-5xl text-balance md:text-6xl lg:text-7xl"
          >
            Das Licht in mir – entdecke deine innere Stärke (Kurs I)
          </h1>
          <p>
            Vertiefung von emotionaler und sozialer Kompetenz, Förderung von
            Selbstvertrauen und innerer Stabilität sowie Resilienz.
          </p>
        </header>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Inhalte & Fokus</h2>
          <ul class="marker:text-manao list-disc space-y-2 pl-6">
            <li>Gefühle, Bedürfnisse & Grenzen wahrnehmen</li>
            <li>
              Umgang mit Emotionen, Selbstregulation, gewaltfreie
              Kommunikation (Giraffensprache)
            </li>
            <li>
              Empathie, Mitgefühl, Konfliktfähigkeit – Beziehungen bewusst
              gestalten
            </li>
            <li>Selbstvertrauen, Mut und Handlungskompetenz</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Zielgruppe</h2>
          <p>
            Vorschulkinder und Kinder der 1. Klasse (begrenzt auf
            6 Teilnehmer)
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Methoden</h2>
          <p>
            Geschichten, Mut- und Stimmübungen, Naturerfahrung, Fantasiereisen,
            Kooperationsspiele, Stimmungsbilder, Eigenraum, Affirmationen,
            Dankbarkeits- und Achtsamkeitsübungen
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-manao text-2xl font-semibold">Investition</h2>
          <dl class="divide-manao/20 divide-y">
            <div
              class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
            >
              <dt>Kursgebühr (6 × 60 min)</dt>
              <dd class="text-manao font-semibold">132 € pro Kind</dd>
            </div>
          </dl>
        </div>

        <div class="space-y-6">
          <h2 class="text-manao text-2xl font-semibold">Termine</h2>
          <p>
            <span class="text-manao font-semibold">Montags</span> von
            14:45 – 15:45 Uhr
          </p>

          <div class="space-y-3">
            <h3 class="text-manao font-semibold">Kurs 1 / Sommer</h3>
            <dl class="divide-manao/20 divide-y">
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Start</dt>
                <dd class="text-manao font-semibold">
                  neuer Kurs ab Herbst 2026
                </dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>weitere Termine</dt>
                <dd class="text-manao font-semibold">—</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Anmeldung bis</dt>
                <dd class="text-manao font-semibold">—</dd>
              </div>
            </dl>
          </div>
        </div>

        <p class="text-manao font-semibold">
          ⇒ Bitte 1 Decke + 1 kleines Kissen mitbringen sowie wettergerecht
          gekleidet.
        </p>

        <ContactButtons />
      </div>
    </section>
  </main>
</Layout>
