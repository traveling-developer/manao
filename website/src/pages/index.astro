---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import headerImage from "../assets/header.webp";
import haende from "../assets/haende_baum.jpg";
import WelcomeHero from "../components/WelcomeHero.astro";
import ImageTextSection from "../components/ImageTextSection.astro";
import IntentionHero from "../components/IntentionHero.astro";
import ColorSection from "../components/ColorSection.astro";
import AngeboteHero from "../components/AngeboteHero.astro";
import ArbeitsweiseHero from "../components/ArbeitsweiseHero.astro";
import AboutMeHero from "../components/AboutMeHero.astro";
---

<Layout title="manao" description="manao">
  <main>
    <Picture
      src={headerImage}
      alt="Header"
      class="aspect-3/1 w-full object-cover"
    />
    <WelcomeHero />
    <ImageTextSection imageMetadata={haende}
      >"Wer auf seine innere Stimme hört, lebt im Einklang mit sich selbst. Dann
      entstehen Freude, Freiheit und Gesundheit." <br />Osho - spiritueller
      Lehrer</ImageTextSection
    >
    <IntentionHero />
    <ColorSection />
    <AngeboteHero />
    <ArbeitsweiseHero />
    <ImageTextSection imageMetadata={haende}
      >"Wer auf seine innere Stimme hört, lebt im Einklang mit sich selbst. Dann
      entstehen Freude, Freiheit und Gesundheit." <br />Osho - spiritueller
      Lehrer</ImageTextSection
    >
    <AboutMeHero />
  </main>
</Layout>
