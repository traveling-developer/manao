---
import Layout from "../layouts/Layout.astro";
import ContactButtons from "../components/ContactButtons.astro";
---

<Layout
  title="Coaching für Kinder, Jugendliche und Erwachsene"
  description="tbd"
>
  <main>
    <section class="mx-auto max-w-3xl px-5 py-12 md:py-16">
      <div class="space-y-10">
        <header class="space-y-5">
          <h1
            class="font-licorice text-manao text-5xl text-balance md:text-6xl lg:text-7xl"
          >
            Coaching für Kinder, Jugendliche & Erwachsene
          </h1>
          <p>
            Für tiefergehende Themen, wiederkehrende Herausforderungen oder wenn
            ein einzelnes Gespräch für eine nachhaltige Veränderung nicht
            ausreicht - wenn ganzheitliche Begleitung sinnvoll ist.
          </p><p>
            Die Basis bildet immer ein Beratungsgespräch vorab. Hier stellen wir
            fest, ob die Chemie stimmt und ich die richtige Person bin, um dich
            oder dein Kind auf diesem Weg zu begleiten (Preise siehe Beratung).
          </p>

          <div class="space-y-4">
            <h2 class="text-manao text-2xl font-semibold">Investition</h2>
            <dl class="divide-manao/20 divide-y">
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Einzelsitzung 60 min</dt>
                <dd class="text-manao font-semibold">78 €</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Einzelsitzung 90 min</dt>
                <dd class="text-manao font-semibold">115 €</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>3er-Paket (3 × 90 min)</dt>
                <dd class="text-manao font-semibold">325 €</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>5er-Paket (5 × 90 min)</dt>
                <dd class="text-manao font-semibold">535 €</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Jede weitere angefangene Viertelstunde (15 min)</dt>
                <dd class="text-manao font-semibold">20 €</dd>
              </div>
            </dl>
          </div>

          <ContactButtons />
        </header>
      </div>
    </section>
  </main>
</Layout>
