---
import Layout from "../layouts/Layout.astro";
import ContactButtons from "../components/ContactButtons.astro";
---

<Layout
  title="Das Licht in mir - Kurs II"
  description="Kurs II: Verbindung zu sich selbst vertiefen, Energie wahrnehmen, Selbstheilungskräfte aktivieren - für Vorschulkinder und Kinder der 1. Klasse."
>
  <main>
    <section class="mx-auto max-w-3xl px-5 py-12 md:py-16">
      <div class="space-y-10">
        <header class="space-y-5">
          <h1
            class="font-licorice text-manao text-5xl text-balance md:text-6xl lg:text-7xl"
          >
            Das Licht in mir – entfache deine innere Kraft (Kurs II)
          </h1>
          <p>
            Die Verbindung zu sich selbst vertiefen, Energie bewusst wahrnehmen,
            kennenlernen verschiedener Methoden, um die eigenen
            Selbstheilungskräfte zu aktivieren – Kurs 1 ist keine
            Voraussetzung.
          </p>
        </header>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Inhalte & Fokus</h2>
          <ul class="marker:text-manao list-disc space-y-2 pl-6">
            <li>Wahrnehmung der eigenen Energie, innere Stärke erfahren</li>
            <li>Ressourcen bewusst nutzen, innere Balance stärken</li>
            <li>Ruhe, Konzentration und Stressbewältigung fördern</li>
            <li>Techniken kennenlernen, um Selbstheilungskräfte zu aktivieren</li>
            <li>eigene Strategien entwickeln, um in Balance zu bleiben</li>
          </ul>
        </div>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Zielgruppe</h2>
          <p>
            Vorschulkinder und Kinder der 1. Klasse (begrenzt auf
            6 Teilnehmer)
          </p>
        </div>

        <div class="space-y-3">
          <h2 class="text-manao text-2xl font-semibold">Methoden</h2>
          <p>
            Atem- und Körperübungen, Dankbarkeits- und Achtsamkeitsübungen,
            Fantasiereisen, Visualisierung & innere Bilder, Affirmationen,
            Kraft-Tiere, Kraft-Orte, Licht- und Energiearbeit
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-manao text-2xl font-semibold">Investition</h2>
          <dl class="divide-manao/20 divide-y">
            <div
              class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
            >
              <dt>Kursgebühr (6 × 60 min)</dt>
              <dd class="text-manao font-semibold">132 € pro Kind</dd>
            </div>
          </dl>
        </div>

        <div class="space-y-6">
          <h2 class="text-manao text-2xl font-semibold">Termine</h2>
          <p>
            <span class="text-manao font-semibold">Montags</span> von
            16:15 – 17:15 Uhr
          </p>

          <div class="space-y-3">
            <h3 class="text-manao font-semibold">Kurs 2 / Sommer</h3>
            <dl class="divide-manao/20 divide-y">
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Start</dt>
                <dd class="text-manao font-semibold">neuer Kurs ab Herbst</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>weitere Termine</dt>
                <dd class="text-manao font-semibold">—</dd>
              </div>
              <div
                class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
              >
                <dt>Anmeldung bis</dt>
                <dd class="text-manao font-semibold">—</dd>
              </div>
            </dl>
          </div>
        </div>

        <p class="text-manao font-semibold">
          ⇒ Bitte 1 Decke + 1 kleines Kissen mitbringen sowie wettergerecht
          gekleidet.
        </p>

        <ContactButtons />
      </div>
    </section>
  </main>
</Layout>
