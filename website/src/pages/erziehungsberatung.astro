---
import Layout from "../layouts/Layout.astro";
import ContactButtons from "../components/ContactButtons.astro";
---

<Layout
  title="Beratung- und Erziehungsberatung"
  description="Einmaliges Beratungsgespräch für Orientierung, erste Strategien und Lösungsansätze."
>
  <main>
    <section class="mx-auto max-w-3xl px-5 py-12 md:py-16">
      <div class="space-y-10">
        <header class="space-y-5">
          <h1
            class="font-licorice text-manao text-5xl text-balance md:text-6xl lg:text-7xl"
          >
            Beratung- und Erziehungsberatung
          </h1>
          <p>
            Unterstützung bei Lebensfragen oder Fragen rund um Erziehung,
            Entwicklung und familiäre Herausforderungen sowie zum Thema
            Hochsensibilität. Ein einmaliges Gespräch, das Orientierung, erste
            Strategien und Lösungen bietet.
          </p>
        </header>

        <div class="space-y-4">
          <h2 class="text-manao text-2xl font-semibold">Investition</h2>
          <dl class="divide-manao/20 divide-y">
            <div
              class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
            >
              <dt>Erstgespräch</dt>
              <dd class="text-manao font-semibold">60 min · 58 €</dd>
            </div>
            <div
              class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 py-3 first:pt-0 last:pb-0"
            >
              <dt>Jede weitere angefangene Viertelstunde</dt>
              <dd class="text-manao font-semibold">15 min · 15 €</dd>
            </div>
          </dl>
        </div>

        <ContactButtons />
      </div>
    </section>
  </main>
</Layout>
